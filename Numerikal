  const iterData = [];
  let converged = false;
  let diverged = false;
  let iter = 0;
  let steps = [];
  const errHistory = []; 

  iterData.push({iter:0, x:[...x], err:'-', diverging:false});

  while(iter < maxIter) {
    iter++;
    const xOld = [...x];
    let stepDesc = `Iterasi ke-${iter} (gunakan nilai terbaru):\n`;
    for(let i=0;i<n;i++) {
      let sum=0;
      let termStr = '';
      for(let j=0;j<n;j++) {
        if(j!==i) {
          sum+=A[i][j]*x[j]; 
          termStr+=`(${fmt(A[i][j],3)}×${fmt(x[j],4)})+`;
        }
      }
      x[i]=(b[i]-sum)/A[i][i];
      stepDesc += `  x${i+1} = (${fmt(b[i],3)} - [${termStr.slice(0,-1)}]) / ${fmt(A[i][i],3)} = ${fmtShort(x[i])}\n`;
    }

    const maxDiff = Math.max(...x.map((v,i)=>Math.abs(v-xOld[i])));
    const maxX = Math.max(...x.map(Math.abs));
    const err = maxX === 0 ? maxDiff : maxDiff / maxX;

    errHistory.push(err);
    const isMagnitudeOverflow = x.some(v=>!isFinite(v) || Math.abs(v) > DIVERGENCE_THRESHOLD);
