// HISTORY
let history = [];
function addHistory(entry) {
  history.unshift({ ...entry, time: new Date() });
  if(history.length > 50) history.pop();
}
function renderHistory() {
  const el = document.getElementById('history-list');
  if(!history.length) {
    el.innerHTML = `<div class="empty-state" style="padding:4rem 0"><div class="empty-icon">◻</div>Belum ada riwayat perhitungan.<br>Mulai dengan memilih metode di atas.</div>`;
    return;
  }
  const methodLabels = {
    'matriks': 'Matriks Balikan',
    'jacobi': 'Lelaran Jacobi',
    'gaussseidel': 'Gauss-Seidel'
  };
  el.innerHTML = history.map((h,i) => `
    <div class="history-item" onclick="showPage('${h.method}')">
      <div>
        <div class="hist-method">${methodLabels[h.method]||h.method}</div>
        <div class="hist-detail">Ordo ${h.size}×${h.size} — ${h.detail}</div>
        <div class="hist-result">${h.result}</div>
      </div>
      <div class="hist-time">${formatTime(h.time)}</div>
    </div>
  `).join('');
}
function clearHistory() {
  history = [];
  renderHistory();
}
function formatTime(d) {
  return d.toLocaleDateString('id-ID',{day:'2-digit',month:'short'}) + ' ' +
    d.toLocaleTimeString('id-ID',{hour:'2-digit',minute:'2-digit'});
}


// UTILITY
function fmt(v, d=6) {
  if(!isFinite(v)) return v > 0 ? '∞' : (v < 0 ? '-∞' : 'NaN');
  if(Math.abs(v) < 1e-10) return '0';
  const s = parseFloat(v.toFixed(d));
  return s.toString();
}
function fmtShort(v) {
  if(!isFinite(v)) return v > 0 ? '∞' : (v < 0 ? '-∞' : 'NaN');
  return parseFloat(v.toFixed(6)).toString();
}
function fmtErr(v) {
  if(!isFinite(v)) return v > 0 ? '∞' : (v < 0 ? '-∞' : 'NaN');
  return v.toExponential(4);
}

function buildMatrixInputs(containerId, n, prefix, readOnly=false) {
  const el = document.getElementById(containerId);
  let html = `<div class="matrix-label-row" style="display:grid;grid-template-columns:24px repeat(${n},1fr);gap:6px;margin-bottom:4px">
    <div></div>`;
  for(let j=0;j<n;j++) html += `<div class="matrix-col-label">x<sub>${j+1}</sub></div>`;
  html += '</div>';
  for(let i=0;i<n;i++) {
    html += `<div class="matrix-row" style="display:grid;grid-template-columns:24px repeat(${n},1fr);gap:6px;margin-bottom:5px">
      <div class="row-label">e${i+1}</div>`;
    for(let j=0;j<n;j++) {
      html += `<input class="matrix-cell" type="number" id="${prefix}_${i}_${j}" placeholder="0" step="any" ${readOnly?'readonly':''}>`;
    }
    html += '</div>';
  }
  el.innerHTML = html;
}

function buildVectorInput(containerId, n, prefix, label='b') {
  const el = document.getElementById(containerId);
  let html = `<div class="matrix-label-row" style="display:grid;grid-template-columns:24px 1fr;gap:6px;margin-bottom:4px">
    <div></div><div class="matrix-col-label">${label}</div></div>`;
  for(let i=0;i<n;i++) {
    html += `<div class="matrix-row" style="display:grid;grid-template-columns:24px 1fr;gap:6px;margin-bottom:5px">
      <div class="row-label">e${i+1}</div>
      <input class="matrix-cell" type="number" id="${prefix}_${i}" placeholder="0" step="any">
    </div>`;
  }
  el.innerHTML = html;
}

function getMatrix(prefix, n) {
  const A = [];
  for(let i=0;i<n;i++) {
    A.push([]);
    for(let j=0;j<n;j++) {
      const raw = document.getElementById(`${prefix}_${i}_${j}`).value.trim();
      A[i].push(raw === '' ? 0 : parseFloat(raw));
    }
  }
  return A;
}
function getVector(prefix, n) {
  const b = [];
  for(let i=0;i<n;i++) {
    const raw = document.getElementById(`${prefix}_${i}`).value.trim();
    b.push(raw === '' ? 0 : parseFloat(raw));
  }
  return b;
}
function setMatrix(prefix, n, A) {
  for(let i=0;i<n;i++) for(let j=0;j<n;j++) document.getElementById(`${prefix}_${i}_${j}`).value = A[i][j];
}
function setVector(prefix, n, b) {
  for(let i=0;i<n;i++) document.getElementById(`${prefix}_${i}`).value = b[i];
}

function clearCellErrors(prefix, n, hasVector) {
  for(let i=0;i<n;i++) {
    for(let j=0;j<n;j++) {
      const cell = document.getElementById(`${prefix}_${i}_${j}`);
      if(cell) cell.classList.remove('cell-error');
    }
  }
}
function validateMatrixInputs(matPrefix, vecPrefix, n) {
  const missing = [];
  for(let i=0;i<n;i++) {
    for(let j=0;j<n;j++) {
      const cell = document.getElementById(`${matPrefix}_${i}_${j}`);
      cell.classList.remove('cell-error');
      if(cell.value.trim() === '') {
        cell.classList.add('cell-error');
        missing.push(`A[${i+1}][${j+1}]`);
      } else if(isNaN(parseFloat(cell.value))) {
        cell.classList.add('cell-error');
        missing.push(`A[${i+1}][${j+1}]`);
      }
    }
  }
  for(let i=0;i<n;i++) {
    const cell = document.getElementById(`${vecPrefix}_${i}`);
    cell.classList.remove('cell-error');
    if(cell.value.trim() === '') {
      cell.classList.add('cell-error');
      missing.push(`b[${i+1}]`);
    } else if(isNaN(parseFloat(cell.value))) {
      cell.classList.add('cell-error');
      missing.push(`b[${i+1}]`);
    }
  }
  return missing;
}

// MATRIX MATH
function matMul(A, B) {
  const n=A.length, m=B[0].length, k=B.length;
  const C = Array.from({length:n},()=>Array(m).fill(0));
  for(let i=0;i<n;i++) for(let j=0;j<m;j++) for(let l=0;l<k;l++) C[i][j]+=A[i][l]*B[l][j];
  return C;
}
function matVec(A, v) { return A.map(row => row.reduce((s,a,j)=>s+a*v[j],0)); }
function identity(n) { return Array.from({length:n},(_,i)=>Array.from({length:n},(_,j)=>i===j?1:0)); }

function invertMatrix(A) {
  const n = A.length;
  const aug = A.map((row,i) => [...row, ...identity(n)[i]]);
  const steps = [];

  for(let col=0;col<n;col++) {
    let maxRow=col;
    for(let row=col+1;row<n;row++) if(Math.abs(aug[row][col])>Math.abs(aug[maxRow][col])) maxRow=row;
    [aug[col],aug[maxRow]] = [aug[maxRow],aug[col]];
    if(maxRow!==col) steps.push({type:'swap',r1:col,r2:maxRow,mat:JSON.parse(JSON.stringify(aug))});

    const pivot = aug[col][col];
    if(Math.abs(pivot)<1e-10) return { inv:null, steps, singular:true, singularCol: col };

    for(let j=0;j<2*n;j++) aug[col][j]/=pivot;
    steps.push({type:'scale',row:col,pivot:pivot,mat:JSON.parse(JSON.stringify(aug))});

    for(let row=0;row<n;row++) {
      if(row===col) continue;
      const factor = aug[row][col];
      if(Math.abs(factor)<1e-12) continue;
      for(let j=0;j<2*n;j++) aug[row][j]-=factor*aug[col][j];
      steps.push({type:'elim',row,col,factor:factor,mat:JSON.parse(JSON.stringify(aug))});
    }
  }
  const inv = aug.map(row=>row.slice(n));
  return {inv, steps, singular:false};
}

function matrixToString(mat, n, highlight=-1) {
  return mat.map((row,i) => {
    const rowStr = row.map(v=>fmt(v,4).padStart(10)).join(' ');
    return i===highlight ? `<span class="highlight-row">${rowStr}</span>` : rowStr;
  }).join('\n');
}

function augMatStr(aug, n, highlight=-1) {
  return aug.map((row,i) => {
    const left = row.slice(0,n).map(v=>fmt(v,4).padStart(8)).join(' ');
    const right = row.slice(n).map(v=>fmt(v,4).padStart(8)).join(' ');
    const s = left + '  |  ' + right;
    return i===highlight ? `<span class="highlight-row">${s}</span>` : s;
  }).join('\n');
}


// MATRIKS BALIKAN
function buildMatriksInput() {
  const n = parseInt(document.getElementById('m-size').value);
  buildMatrixInputs('m-matrix-input', n, 'ma');
  buildVectorInput('m-vector-input', n, 'mb');
}

function fillMatriksExample() {
  const n = parseInt(document.getElementById('m-size').value);
  const examples = {
    2: { A:[[4,-1],[-2,3]], b:[8,2] },
    3: { A:[[3,1,-1],[2,4,1],[-1,2,5]], b:[4,1,1] },
    4: { A:[[10,-1,2,0],[-1,11,-1,3],[2,-1,10,-1],[0,3,-1,8]], b:[6,25,-11,15] },
    5: { A:[[9,1,0,0,0],[1,8,1,0,0],[0,1,7,1,0],[0,0,1,6,1],[0,0,0,1,5]], b:[9,10,9,8,6] }
  };
  const ex = examples[n]||examples[3];
  setMatrix('ma',n,ex.A); setVector('mb',n,ex.b);
}

function solveMatriks() {
  const n = parseInt(document.getElementById('m-size').value);
  const el = document.getElementById('m-result');

  const missing = validateMatrixInputs('ma','mb',n);
  if(missing.length) {
    el.innerHTML = `<div class="alert-box alert-danger">
      <span class="alert-title">✕ Input belum lengkap</span>
      Sel berikut masih kosong atau bukan angka: ${missing.join(', ')}. Lengkapi sel yang ditandai merah, lalu hitung ulang.
    </div>`;
    return;
  }

  const A = getMatrix('ma',n), b = getVector('mb',n);

  const result = invertMatrix(A);
  if(result.singular) {
    el.innerHTML = `<div class="alert-box alert-danger">
      <span class="alert-title">✕ Matriks singular — tidak dapat dibalik</span>
      Eliminasi Gauss-Jordan menghasilkan pivot nol (mendekati nol) pada kolom ${result.singularCol+1}, bahkan setelah pertukaran baris. Ini berarti det(A) = 0, sehingga A⁻¹ tidak ada dan sistem ini tidak punya solusi tunggal (bisa berarti tak ada solusi, atau solusinya tak hingga banyak).
    </div>`;
    return;
  }
  const {inv, steps} = result;
  const x = matVec(inv, b);

  const solStr = x.map((v,i)=>`x${i+1} = ${fmtShort(v)}`).join(', ');
  addHistory({ method:'matriks', size:n, detail:`A[${n}×${n}]`, result: solStr });

  let stepsHtml = '';
  let stepNum = 1;

  const aug0 = A.map((row,i)=>[...row,...identity(n)[i]]);
  stepsHtml += `
    <div class="step-item">
      <div class="step-head">LANGKAH 1 — Bentuk Matriks Augmented [A|I]</div>
      <div class="step-body">Tambahkan matriks identitas di sebelah kanan A</div>
      <div class="step-matrix">${augMatStr(aug0,n)}</div>
    </div>`;

  steps.forEach((s) => {
    let desc = '';
    let highlightRow = -1;
    if(s.type==='swap') { desc = `Tukar baris ${s.r1+1} ↔ baris ${s.r2+1} (partial pivoting)`; highlightRow = s.r1; }
    else if(s.type==='scale') { desc = `Normalisasi baris ${s.row+1} ÷ ${fmt(s.pivot,4)}`; highlightRow = s.row; }
    else { desc = `Eliminasi: baris ${s.row+1} −= (${fmt(s.factor,4)}) × baris ${s.col+1}`; highlightRow = s.row; }
    stepsHtml += `
      <div class="step-item">
        <div class="step-head">LANGKAH ${stepNum+1} — ${desc}</div>
        <div class="step-matrix">${augMatStr(s.mat,n,highlightRow)}</div>
      </div>`;
    stepNum++;
  });

  stepsHtml += `
    <div class="step-item">
      <div class="step-head">HASIL — Matriks Balikan A⁻¹</div>
      <div class="step-body">Bagian kanan augmented setelah eliminasi Gauss-Jordan</div>
      <div class="step-matrix">${matrixToString(inv,n)}</div>
    </div>
    <div class="step-item">
      <div class="step-head">FINAL — x = A⁻¹ · b</div>
      <div class="step-body">Kalikan matriks balikan dengan vektor b</div>
      <div class="step-matrix">${x.map((v,i)=>`x${i+1} = ${fmtShort(v)}`).join('\n')}</div>
    </div>`;

  const Ax = matVec(A, x);
  const residual = Ax.map((v,i)=>v-b[i]);
  const maxResidual = Math.max(...residual.map(Math.abs));
  stepsHtml += `
    <div class="step-item">
      <div class="step-head">VERIFIKASI — Ax dibandingkan dengan b</div>
      <div class="step-body">Residual maksimum |Ax − b| = ${maxResidual.toExponential(3)} (mendekati 0 berarti solusi valid)</div>
      <div class="step-matrix">${Ax.map((v,i)=>`(Ax)${i+1} = ${fmtShort(v)}   vs   b${i+1} = ${fmtShort(b[i])}`).join('\n')}</div>
    </div>`;
    
  const infoHtml = `<div class="alert-box" style="background: rgba(90,128,192,0.1); border: 1px solid rgba(90,128,192,0.35); color: var(--text); margin-bottom: 1rem;">
      <span class="alert-title" style="color: #5a80c0;">ℹ Catatan Komputasi Profesional</span>
      Metode Invers Eksplisit (A⁻¹b) sangat baik untuk visualisasi edukasi. Namun, dalam library industri (seperti NumPy/MATLAB) untuk matriks sistem besar (N > 1000), algoritma <b>Dekomposisi LU</b> jauh lebih disukai karena lebih cepat dan meminimalkan galat pembulatan.
  </div>`;

  el.innerHTML = `
    <div class="result-header">
      <div class="result-title">Solusi Sistem</div>
      <span class="badge badge-success">✓ Berhasil</span>
    </div>
    <div class="results-grid">
      ${x.map((v,i)=>`<div class="res-card"><div class="var">x${i+1}</div><div class="val">${fmtShort(v)}</div></div>`).join('')}
    </div>
    ${infoHtml}
    <div class="divider"></div>
    <div style="font-family:var(--mono);font-size:0.72rem;color:var(--text3);letter-spacing:0.08em;margin-bottom:0.5rem">LANGKAH-LANGKAH GAUSS-JORDAN</div>
    <div class="steps-container">${stepsHtml}</div>`;
}



// JACOBI
function buildJacobiInput() {
  const n = parseInt(document.getElementById('j-size').value);
  buildMatrixInputs('j-matrix-input', n, 'ja');
  buildVectorInput('j-vector-input', n, 'jb');
  buildVectorInput('j-init-input', n, 'jx0', 'x⁰');
  for(let i=0;i<n;i++) document.getElementById(`jx0_${i}`).value = 0;
}

function fillJacobiExample() {
  const n = parseInt(document.getElementById('j-size').value);
  const ex3 = { A:[[5,1,1],[2,8,1],[1,1,4]], b:[7,10,6] };
  const ex2 = { A:[[4,-1],[-1,3]], b:[8,7] };
  const ex4 = { A:[[10,1,0,0],[1,8,1,0],[0,1,6,1],[0,0,1,7]], b:[11,10,8,8] };
  const examples = {2:ex2,3:ex3,4:ex4};
  const ex = examples[n]||ex3;
  setMatrix('ja',n,ex.A); setVector('jb',n,ex.b);
  for(let i=0;i<n;i++) document.getElementById(`jx0_${i}`).value=0;
}

function isDiagonallyDominant(A) {
  const n=A.length;
  for(let i=0;i<n;i++) {
    let sum=0;
    for(let j=0;j<n;j++) if(j!==i) sum+=Math.abs(A[i][j]);
    if(Math.abs(A[i][i])<=sum) return false;
  }
  return true;
}

function findZeroDiagonal(A) {
  const n = A.length;
  const zeros = [];
  for(let i=0;i<n;i++) if(Math.abs(A[i][i]) < 1e-12) zeros.push(i);
  return zeros;
}

const DIVERGENCE_THRESHOLD = 1e8;
const GROWING_ERROR_STREAK_LIMIT = 5;
function isErrorGrowingConsistently(errHistory) {
  if(errHistory.length < GROWING_ERROR_STREAK_LIMIT + 1) return false;
  const recent = errHistory.slice(-(GROWING_ERROR_STREAK_LIMIT+1));
  for(let k=1;k<recent.length;k++) {
    if(!(recent[k] > recent[k-1])) return false; 
  }
  return true;
}

function solveJacobi() {
  const n = parseInt(document.getElementById('j-size').value);
  const el = document.getElementById('j-result');

  const missing = validateMatrixInputs('ja','jb',n);
  let x0valid = true;
  for(let i=0;i<n;i++) {
    const cell = document.getElementById(`jx0_${i}`);
    if(cell.value.trim() !== '' && isNaN(parseFloat(cell.value))) { x0valid = false; cell.classList.add('cell-error'); }
    else cell.classList.remove('cell-error');
  }
  if(missing.length || !x0valid) {
    el.innerHTML = `<div class="alert-box alert-danger">
      <span class="alert-title">✕ Input belum lengkap</span>
      ${missing.length ? 'Sel berikut masih kosong atau bukan angka: ' + missing.join(', ') + '. ' : ''}${!x0valid ? 'Tebakan awal x⁰ berisi nilai yang bukan angka.' : ''} Lengkapi sel yang ditandai merah, lalu hitung ulang.
    </div>`;
    return;
  }

  const A = getMatrix('ja',n), b = getVector('jb',n);
  const tol = parseFloat(document.getElementById('j-tol').value)||1e-4;
  const maxIter = parseInt(document.getElementById('j-maxiter').value)||50;
  let x = getVector('jx0',n);
  const dominant = isDiagonallyDominant(A);

  const zeroDiag = findZeroDiagonal(A);
  if(zeroDiag.length) {
    el.innerHTML = `<div class="alert-box alert-danger">
      <span class="alert-title">✕ Elemen diagonal bernilai nol</span>
      A[${zeroDiag.map(i=>i+1).join(', ')}][${zeroDiag.map(i=>i+1).join(', ')}] = 0. Metode Jacobi membagi dengan elemen diagonal A[i][i] di setiap langkah, sehingga iterasi tidak bisa dijalankan (hasilnya akan tak terhingga). Susun ulang urutan persamaan supaya tidak ada elemen diagonal nol, atau gunakan Metode Matriks Balikan.
    </div>`;
    return;
  }

  const iterData = [];
  let converged = false;
  let diverged = false;
  let iter = 0;
  let steps = [];
  const errHistory = []; 

  iterData.push({iter:0, x:[...x], err:'-', diverging:false});

  while(iter < maxIter) {
    iter++;
    const xNew = new Array(n);
    let stepDesc = `Iterasi ke-${iter}:\n`;
    for(let i=0;i<n;i++) {
      let sum=0;
      let termStr = '';
      for(let j=0;j<n;j++) {
        if(j!==i) { sum+=A[i][j]*x[j]; termStr+=`(${fmt(A[i][j],3)}×${fmt(x[j],4)})+`; }
      }
      xNew[i]=(b[i]-sum)/A[i][i];
      stepDesc += `  x${i+1} = (${fmt(b[i],3)} - [${termStr.slice(0,-1)}]) / ${fmt(A[i][i],3)} = ${fmtShort(xNew[i])}\n`;
    }

    const maxDiff = Math.max(...xNew.map((v,i)=>Math.abs(v-x[i])));
    const maxX = Math.max(...xNew.map(Math.abs));
    const err = maxX === 0 ? maxDiff : maxDiff / maxX;

    errHistory.push(err);
    const isMagnitudeOverflow = xNew.some(v=>!isFinite(v) || Math.abs(v) > DIVERGENCE_THRESHOLD);
    const isOverflow = isMagnitudeOverflow || isErrorGrowingConsistently(errHistory);
    
    iterData.push({iter, x:[...xNew], err, diverging:isOverflow});
    steps.push({iter, desc:stepDesc, x:[...xNew], err});

    x = xNew;

    if(isOverflow) { diverged = true; break; }
    if(err < tol) { converged = true; break; }
  }

  const solStr = converged
    ? x.map((v,i)=>`x${i+1}=${fmtShort(v)}`).join(', ')
    : (diverged ? 'Divergen — tidak ada solusi' : 'Tidak konvergen dalam batas iterasi');
  addHistory({method:'jacobi',size:n,detail:`tol=${tol}, iter=${iter}`,result:solStr});

  renderIterResult('j-result', x, n, iterData, steps, converged, diverged, iter, 'Jacobi', dominant, tol, maxIter, A, b);
}


