  const solStr = converged
    ? x.map((v,i)=>`x${i+1}=${fmtShort(v)}`).join(', ')
    : (diverged ? 'Divergen — tidak ada solusi' : 'Tidak konvergen dalam batas iterasi');
  addHistory({method:'gaussseidel',size:n,detail:`tol=${tol}, iter=${iter}`,result:solStr});

  renderIterResult('gs-result', x, n, iterData, steps, converged, diverged, iter, 'Gauss-Seidel', dominant, tol, maxIter, A, b);
}


// ============================================================
// CONVERGENCE CHART (baru — tidak mengubah logika solveJacobi/solveGS)
// Menggambar grafik error per iterasi (skala log) memakai iterData
// yang sudah dihasilkan oleh fungsi iterasi, tanpa menghitung ulang apapun.
// ============================================================
function renderConvergenceChart(iterData, tol, methodName) {
  // Ambil pasangan (iter, err) yang valid (err numerik, iter>=1)
  const pts = iterData.filter(d => typeof d.err === 'number' && d.err > 0);
  if (pts.length < 2) return ''; // tidak cukup data untuk digambar

  const W = 640, H = 220, padL = 46, padR = 16, padT = 14, padB = 28;
  const plotW = W - padL - padR, plotH = H - padT - padB;

  const iters = pts.map(d => d.iter);
  const errs = pts.map(d => d.err);
  const logErrs = errs.map(e => Math.log10(e));
  const logTol = Math.log10(tol);

  const minIter = 0, maxIter = Math.max(...iters);
  let minLog = Math.min(...logErrs, logTol);
  let maxLog = Math.max(...logErrs, logTol);
  if (minLog === maxLog) { minLog -= 1; maxLog += 1; }
  const pad = (maxLog - minLog) * 0.08;
  minLog -= pad; maxLog += pad;

  const xScale = it => padL + (maxIter === minIter ? 0 : (it - minIter) / (maxIter - minIter)) * plotW;
  const yScale = lg => padT + (1 - (lg - minLog) / (maxLog - minLog)) * plotH;

  // Garis error
  let path = pts.map((d, i) => `${i === 0 ? 'M' : 'L'} ${xScale(d.iter).toFixed(1)} ${yScale(Math.log10(d.err)).toFixed(1)}`).join(' ');

  // Titik-titik
  let dots = pts.map(d => {
    const cx = xScale(d.iter).toFixed(1), cy = yScale(Math.log10(d.err)).toFixed(1);
    const color = d.diverging ? 'var(--danger)' : 'var(--gold2)';
    return `<circle cx="${cx}" cy="${cy}" r="2.6" fill="${color}"><title>Iterasi ${d.iter}: ε=${fmtErr(d.err)}</title></circle>`;
  }).join('');

  // Garis toleransi (putus-putus)
  const yTol = yScale(logTol).toFixed(1);
  const tolLine = `<line x1="${padL}" y1="${yTol}" x2="${W - padR}" y2="${yTol}" class="chart-gridline" stroke="var(--info)"/>`;

  // Grid horizontal + label sumbu-y (skala 10^n)
  let gridHtml = '';
  const startPow = Math.ceil(minLog), endPow = Math.floor(maxLog);
  for (let p = startPow; p <= endPow; p++) {
    const y = yScale(p).toFixed(1);
    gridHtml += `<line x1="${padL}" y1="${y}" x2="${W - padR}" y2="${y}" class="chart-gridline"/>`;
    gridHtml += `<text x="${padL - 6}" y="${Number(y) + 3}" text-anchor="end" class="chart-svg-label">10^${p}</text>`;
  }

  // Label sumbu-x (iterasi)
  const xTicks = Math.min(maxIter, 8);
  let xLabels = '';
  for (let t = 0; t <= xTicks; t++) {
    const it = Math.round((maxIter / xTicks) * t);
    const x = xScale(it).toFixed(1);
    xLabels += `<text x="${x}" y="${H - 8}" text-anchor="middle" class="chart-svg-label">${it}</text>`;
  }

  const svg = `
    <svg viewBox="0 0 ${W} ${H}" width="100%" height="${H}" xmlns="http://www.w3.org/2000/svg">
      ${gridHtml}
      ${tolLine}
      <line x1="${padL}" y1="${padT}" x2="${padL}" y2="${H - padB}" class="chart-axis"/>
      <line x1="${padL}" y1="${H - padB}" x2="${W - padR}" y2="${H - padB}" class="chart-axis"/>
      <path d="${path}" fill="none" stroke="var(--gold2)" stroke-width="1.6"/>
      ${dots}
      ${xLabels}
      <text x="${(padL + W - padR) / 2}" y="${H - 1}" text-anchor="middle" class="chart-svg-label" opacity="0.7">ITERASI (k)</text>
    </svg>`;

  return `<div class="chart-wrap">
      <div style="font-family:var(--mono);font-size:0.72rem;color:var(--text3);letter-spacing:0.08em;margin-bottom:0.4rem">GRAFIK KONVERGENSI ERROR — ${methodName}</div>
      ${svg}
      <div class="chart-legend">
        <div class="chart-legend-item"><span class="chart-legend-dot" style="background:var(--gold2)"></span> Error (ε) tiap iterasi</div>
        <div class="chart-legend-item"><span class="chart-legend-dot" style="background:var(--info)"></span> Garis toleransi (${fmtErr(tol)})</div>
        <div class="chart-legend-item"><span class="chart-legend-dot" style="background:var(--danger)"></span> Titik divergen</div>
      </div>
    </div>`;
}


// ============================================================
// RENDER ITERATION RESULT (shared by Jacobi & Gauss-Seidel)
// ============================================================
function renderIterResult(elId, x, n, iterData, steps, converged, diverged, iter, methodName, dominant, tol, maxIter, A, b) {
  const el = document.getElementById(elId);
  let html = '';

  // Status
  if(converged) {
    html += `<div class="result-header">
      <div class="result-title">Solusi Sistem (${methodName})</div>
      <span class="badge badge-success">✓ Konvergen — ${iter} iterasi</span>
    </div>`;
    html += `<div class="results-grid">
      ${x.map((v,i)=>`<div class="res-card"><div class="var">x${i+1}</div><div class="val">${fmtShort(v)}</div></div>`).join('')}
    </div>`;
  } else if(diverged) {
    html += `<div class="result-header">
      <div class="result-title">Hasil (${methodName})</div>
      <span class="badge badge-danger">✕ Divergen</span>
    </div>`;
    html += `<div class="alert-box alert-danger">
      <span class="alert-title">Iterasi Divergen</span>
      Nilai variabel terus membesar dan tidak menuju konvergensi setelah ${iter} iterasi. 
      ${!dominant ? 'Matriks A tidak dominan diagonal — konvergensi metode iteratif tidak dijamin. ' : ''}
      Pertimbangkan untuk menggunakan Metode Matriks Balikan sebagai alternatif.
    </div>`;
  } else {
    html += `<div class="result-header">
      <div class="result-title">Hasil (${methodName})</div>
      <span class="badge badge-warning">⚠ Belum Konvergen</span>
    </div>`;
    html += `<div class="alert-box alert-warning">
      <span class="alert-title">Batas Iterasi Tercapai</span>
      Setelah ${maxIter} iterasi, error relatif belum kurang dari toleransi ${tol}. Coba tingkatkan jumlah iterasi maksimum atau periksa kondisi matriks.
    </div>`;
    html += `<div class="results-grid">
      ${x.map((v,i)=>`<div class="res-card"><div class="var">x${i+1}</div><div class="val">${fmtShort(v)}</div></div>`).join('')}
    </div>`;
  }

  // Diagonal dominance
  if(!dominant) {
    html += `<div class="info-row">
      <span class="info-icon">⚠</span>
      <span>Matriks A tidak dominan diagonal ketat — konvergensi ${methodName} tidak dijamin.</span>
    </div>`;
  } else {
    html += `<div class="info-row">
      <span class="info-icon">✓</span>
      <span>Matriks A dominan diagonal ketat — konvergensi ${methodName} dijamin.</span>
    </div>`;
  }

  // Iteration table
  html += `<div class="divider"></div>
    <div style="font-family:var(--mono);font-size:0.72rem;color:var(--text3);letter-spacing:0.08em;margin-bottom:0.5rem">TABEL ITERASI</div>`;
  html += `<div class="iter-table-wrap"><table class="iter-table"><thead><tr><th>k</th>`;
  for(let i=0;i<n;i++) html += `<th>x<sub>${i+1}</sub></th>`;
  html += `<th>ε</th></tr></thead><tbody>`;
  iterData.forEach(d => {
    const cls = d.diverging ? ' class="row-diverging"' : '';
    html += `<tr${cls}><td>${d.iter}</td>`;
    d.x.forEach(v => html += `<td>${fmtShort(v)}</td>`);
    html += `<td>${typeof d.err === 'string' ? '—' : fmtErr(d.err)}</td></tr>`;
  });
  html += `</tbody></table></div>`;

  // Grafik konvergensi (baru) — dibangun dari iterData yang sudah ada, tanpa hitung ulang
  html += renderConvergenceChart(iterData, tol, methodName);

  // Step details
  if(steps.length > 0) {
    html += `<div class="divider"></div>
      <div style="font-family:var(--mono);font-size:0.72rem;color:var(--text3);letter-spacing:0.08em;margin-bottom:0.5rem">DETAIL PERHITUNGAN</div>`;
    html += `<div class="steps-container">`;
    steps.forEach(s => {
      html += `<div class="step-item">
        <div class="step-head">ITERASI KE-${s.iter}</div>
        <div class="step-matrix">${s.desc}</div>
      </div>`;
    });
    html += `</div>`;
  }

  // Verification
  if(converged) {
    const Ax = matVec(A, x);
    const residual = Ax.map((v,i) => Math.abs(v - b[i]));
    const maxResidual = Math.max(...residual);
    html += `<div class="divider"></div>
      <div class="step-item">
        <div class="step-head">VERIFIKASI — Ax dibandingkan dengan b</div>
        <div class="step-body">Residual maksimum |Ax − b| = ${maxResidual.toExponential(3)}</div>
        <div class="step-matrix">${Ax.map((v,i)=>`(Ax)${i+1} = ${fmtShort(v)}   vs   b${i+1} = ${fmtShort(b[i])}`).join('\n')}</div>
      </div>`;
  }

  el.innerHTML = html;
}


